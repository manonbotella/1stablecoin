<presentation titre="Les Stablecoins et les Banques Françaises" niveau="Master 2 Finance" matiere="Finance Digitale" annee="2026">
<!--  ============================================================  -->
<!--  1. DÉFINITION DES STABLECOINS                                 -->
<!--  ============================================================  -->
<section id="1" titre="Définition du Stablecoin">
<definition> Un stablecoin est un cryptoactif dont l'objectif est de maintenir un prix (quasi) fixe, indexé sur un actif de référence — le plus souvent une monnaie fiduciaire (USD, EUR) — tout en conservant les propriétés de la blockchain : programmabilité, transfert 24/7 et coût réduit. </definition>
<types_stablecoins>
<type id="1" nom="Fiat-Backed" label="Adossé à la monnaie fiduciaire">
<description>Chaque jeton est couvert par un actif « sûr » détenu en réserve : cash, dépôts, T-Bills, titres de créances.</description>
<mecanisme>Dépôt 1 USD → émission 1 token → burn token → remboursement 1 USD</mecanisme>
<exemples>
<exemple ticker="USDT" emetteur="Tether" capitalisation_md="184"/>
<exemple ticker="USDC" emetteur="Circle" capitalisation_md="75"/>
</exemples>
</type>
<type id="2" nom="Crypto-Backed" label="Adossé à des cryptoactifs">
<description>Couverture par d'autres cryptoactifs (ETH, wBTC), souvent avec sur-collatéralisation.</description>
<mecanisme>Collatéral crypto bloqué dans smart contracts → liquidation automatique si valeur chute</mecanisme>
<exemples>
<exemple ticker="DAI" emetteur="MakerDAO" type="décentralisé"/>
</exemples>
</type>
<type id="3" nom="Commodity-Backed" label="Adossé à des matières premières">
<description>Indexés sur l'or ou d'autres commodities, avec actifs physiques détenus en réserve.</description>
<exemples>
<exemple ticker="DGX" emetteur="Digix Gold" sous_jacent="Or"/>
</exemples>
</type>
<type id="4" nom="Algorithmique" label="Non adossé — algorithmique">
<description>Stabilité recherchée via algorithmes ajustant l'offre de tokens. Fragile si la confiance s'effondre.</description>
<avertissement>Plusieurs modèles ont échoué : spirale de la mort (ex. TerraUSD -99% en 2022)</avertissement>
<exemples>
<exemple ticker="UST" emetteur="Terra" statut="EFFONDRÉ" date_crash="2022-05"/>
</exemples>
</type>
</types_stablecoins>
<chiffres_cles>
<chiffre indicateur="Capitalisation totale stablecoins" valeur="~300" unite="Md$" date="2025"/>
<chiffre indicateur="Volume transactions annuelles" valeur=">33 000" unite="Md$" date="2025"/>
<chiffre indicateur="Part adossée au dollar USD" valeur=">90" unite="%" date="2025"/>
<chiffre indicateur="Croissance depuis 2020" valeur="×10" unite="" note="De 30 Md$ à 300 Md$"/>
<chiffre indicateur="USDT capitalisation" valeur="184" unite="Md$" date="2025"/>
<chiffre indicateur="USDC capitalisation" valeur="75" unite="Md$" date="2025"/>
<chiffre indicateur="Stablecoins en euro" valeur="~500" unite="M$" note="Très minoritaires"/>
<chiffre indicateur="Prévision 2028" valeur="2 000" unite="Md$" source="Citigroup"/>
<chiffre indicateur="Prévision 2030" valeur="3 700" unite="Md$" source="Citigroup"/>
</chiffres_cles>
</section>
<!--  ============================================================  -->
<!--  2. MÉCANISMES DE MAINTIEN DE LA PARITÉ                        -->
<!--  ============================================================  -->
<section id="2" titre="Mécanismes de maintien de la parité">
<flux_fiat_backed label="Fonctionnement d'un stablecoin fiat-backed">
<etape ordre="1" nom="Dépôt">Le client dépose 100 € chez l'émetteur</etape>
<etape ordre="2" nom="Réserve">L'émetteur place les fonds en réserves sécurisées (cash, T-Bills)</etape>
<etape ordre="3" nom="Émission">100 tokens sont créés (mint) sur la blockchain</etape>
<etape ordre="4" nom="Circulation">Les tokens circulent : paiements, trading, DeFi 24/7</etape>
<etape ordre="5" nom="Rachat">Le détenteur rend les tokens → ils sont détruits (burn) → 100 € remboursés</etape>
</flux_fiat_backed>
<mecanisme_arbitrage>
<cas condition="prix_marché_superieur_1" action="Émettre tokens à 1$ → vendre plus cher → offre ↑ → prix ↓ vers 1$"/>
<cas condition="prix_marché_inferieur_1" action="Acheter tokens bon marché → rembourser à 1$ → offre ↓ → prix ↑ vers 1$"/>
<prerequis>Transparence des réserves, confiance dans l'émetteur, absence de frictions majeures</prerequis>
</mecanisme_arbitrage>
<trois_blocs_mecanismes>
<bloc id="1" nom="Collatéral / Adossement" types="Fiat | Crypto | Matières premières | Algorithmique (sans réserve)"/>
<bloc id="2" nom="Ajustement de la valeur" types="Arbitrage + droit de rachat | Sur-collatéralisation + liquidations | Algorithme d'offre"/>
<bloc id="3" nom="Infrastructure technique" types="Smart contracts | Oracles de prix | Gouvernance (DAO ou centralisée)"/>
</trois_blocs_mecanismes>
<sur_collateralisation label="Crypto-backed — liquidations automatiques">
<principe>Valeur collatéral > Valeur stablecoins émis (ex. 150€ collatéral pour 100€ stablecoins)</principe>
<declencheur>Si valeur collatéral chute sous seuil → vente automatique du collatéral pour rembourser</declencheur>
</sur_collateralisation>
<stablecoins_algorithmiques label="Logique de banque centrale algorithmique">
<si_prix_inferieur_1>Réduction offre par rachat/burn ou verrouillage → prix remonte</si_prix_inferieur_1>
<si_prix_superieur_1>Émission nouveaux tokens → distribution ou vente → prix baisse</si_prix_superieur_1>
<risque>Aucun prêteur en dernier ressort — fragile si confiance disparaît</risque>
</stablecoins_algorithmiques>
</section>
<!--  ============================================================  -->
<!--  3. CONTEXTE FRANCE ET RÉGLEMENTATION MICA                     -->
<!--  ============================================================  -->
<section id="3" titre="Contexte France et Réglementation MiCA">
<mica label="Markets in Crypto-Assets Regulation">
<description>Première réglementation mondiale complète dédiée aux crypto-actifs. Applicable en Europe depuis 2024.</description>
<categories_stablecoins>
<categorie code="ART" nom="Asset-Referenced Token">
<definition>Adossé à un panier d'actifs non-monétaires</definition>
<fonds_propres_min>2% des encours (non-significatif) | 3% + buffer (significatif > 10 Md€)</fonds_propres_min>
<reserves>Diversifiées, interdiction modèles algorithmiques purs</reserves>
<superviseur>AMF</superviseur>
</categorie>
<categorie code="EMT" nom="Electronic Money Token">
<definition>Adossé 1:1 à une monnaie unique (EUR, USD…)</definition>
<droit_remboursement>À la valeur nominale, instantané</droit_remboursement>
<reserves>Actifs liquides sûrs : cash BCE, T-Bills < 3 mois, dépôts overnight</reserves>
<superviseur>ACPR</superviseur>
</categorie>
</categories_stablecoins>
<obligations_cles>
<obligation>Réserves 100% en actifs de haute qualité — ségrégation stricte</obligation>
<obligation>Interdiction de versement d'intérêts aux détenteurs</obligation>
<obligation>Audits mensuels obligatoires par tiers indépendant</obligation>
<obligation>Rachat instantané à la valeur nominale garanti</obligation>
<obligation>Livre blanc (white paper) validé et publié</obligation>
<obligation>Plan de résolution et de liquidation</obligation>
<obligation>Contrôles AML/KYC renforcés — reporting TRACFIN</obligation>
</obligations_cles>
<calendrier>
<date echeance="2024-06-30" mesure="Règles ART/EMT applicables — autorisation obligatoire pour émetteurs"/>
<date echeance="2024-12-30" mesure="Régime CASP (Crypto-Asset Service Providers) pour plateformes et services"/>
<date echeance="2025-12-31" mesure="Fin enregistrement PSAN AMF — migration vers agrément CASP MiCA"/>
<date echeance="2026-07-01" mesure="Fin période transitoire — seuls acteurs agréés MiCA opèrent légalement"/>
</calendrier>
<sanctions>
<sanction type="amende_max">5% du chiffre d'affaires global</sanction>
<sanction type="autre">Retrait d'agrément, injonctions</sanction>
<sanction type="europeen">Supervision collégiale ESMA/ABE pour stablecoins > 1 Md€</sanction>
</sanctions>
</mica>
<superviseurs_france>
<superviseur code="AMF" nom="Autorité des Marchés Financiers" perimetre="ART, services crypto-actifs (CASP), plateformes"/>
<superviseur code="ACPR" nom="Autorité de Contrôle Prudentiel et de Résolution" perimetre="EMT (risque monétaire), émetteurs bancaires"/>
</superviseurs_france>
</section>
<!--  ============================================================  -->
<!--  4. RÔLE DES STABLECOINS DANS LES BANQUES FRANÇAISES           -->
<!--  ============================================================  -->
<section id="4" titre="Rôle des stablecoins dans les banques françaises">
<usages>
<usage id="1" categorie="Règlement d'actifs tokenisés">
<description>Stablecoins utilisés comme monnaie de règlement pour obligations tokenisées, actions tokenisées et fonds on-chain</description>
<acteurs>SG-FORGE, BNP, CACEIS</acteurs>
<horizon>Déjà opérationnel (institutionnel)</horizon>
</usage>
<usage id="2" categorie="Paiements cross-border">
<description>Transferts instantanés 24/7 à coûts réduits vs SWIFT pour entreprises et corporate banking</description>
<avantage>Délai : quelques secondes vs 1-3 jours | Coût réduit | Pas d'intermédiaires multiples</avantage>
<horizon>En déploiement</horizon>
</usage>
<usage id="3" categorie="Collatéral en DeFi">
<description>Prêts, emprunts, pools de liquidité, produits à rendement pour clients institutionnels</description>
<horizon>Expérimental / en développement</horizon>
</usage>
<usage id="4" categorie="Cash Management">
<description>Trésorerie tokenisée, money market on-chain, rendement programmable via smart contracts</description>
<horizon>En développement</horizon>
</usage>
<usage id="5" categorie="Conservation (Custody)">
<description>CACEIS, SG-FORGE, Delubac conservent stablecoins pour fonds et institutionnels sous agrément MiCA</description>
<horizon>Opérationnel</horizon>
</usage>
<usage id="6" categorie="Émission de stablecoins en euros">
<description>Banques émettrices de stablecoins MiCA-compliant en euros pour finance institutionnelle</description>
<exemples>EURCV (SG-FORGE), USDCV (SG-FORGE), Qivalis (BNP Paribas)</exemples>
<horizon>Opérationnel (SG) / 2026 (BNP)</horizon>
</usage>
</usages>
<note_importante>Aujourd'hui les usages sont essentiellement B2B et institutionnels. Le grand public français utilise principalement USDT/USDC via des plateformes crypto tierces.</note_importante>
</section>
<!--  ============================================================  -->
<!--  5. DÉTAIL DES 5 GRANDES BANQUES FRANÇAISES                    -->
<!--  ============================================================  -->
<section id="5" titre="Détail des 5 grandes banques françaises">
<banque id="1" nom="Société Générale" entite_crypto="SG-FORGE" maturite_pct="95" statut="LEADER">
